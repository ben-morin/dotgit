# ghostty +show-config --default --docs
# https://ghostty.org/docs/config

auto-update-channel = tip
auto-update = check

shell-integration = none
shell-integration-features = sudo,no-cursor,ssh-env,path

font-family = "JetBrainsMono Nerd Font"
font-feature = "-calt"

macos-icon = xray
macos-custom-icon = ~/.config/ghostty/icons/ghostty-black.icns

window-padding-x = 8
window-padding-y = 0,8
window-padding-balance = true

cursor-style = block
cursor-style-blink = false

bell-features = no-title, border

# minimum-contrast = 1.1
theme = seven
