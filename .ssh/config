# Added by OrbStack: 'orb' SSH host for Linux machines
# This only works if it's at the top of ssh_config (before any Host blocks).
# This won't be added again if you remove it.
Include ~/.orbstack/ssh/config

Host *
  SetEnv TERM=xterm-256color
#		PubkeyAcceptedKeyTypes=+ssh-dss
  AddressFamily inet
  LogLevel INFO
  UseKeychain yes
  AddKeysToAgent yes

Host 192.168.1.1 192.168.7.1 192.168.10.1
  StrictHostKeyChecking no
  User root

Host 192.168.77.1??
  UserKnownHostsFile /dev/null
  StrictHostKeyChecking no
  User root

Host db1 web1 web2
  User sevence

Host github.com
  User git
  Hostname github.com
  PreferredAuthentications publickey
  UseKeychain yes
  AddKeysToAgent yes
  IdentityFile ~/.ssh/github

Host portal.boomtime.com
  User ubuntu
  PreferredAuthentications publickey
  IdentityFile ~/.ssh/aws-oregon

Host zw-devops.centralus.cloudapp.azure.com
  User zwadmin

Host *.ssh.wpengine.net
	IdentitiesOnly yes
	StrictHostKeyChecking no
  UserKnownHostsFile /tmp/wpengin-known-hosts

