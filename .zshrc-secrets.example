# Template for ~/.zshrc-secrets — copy to ~/.zshrc-secrets and fill in.
#   cp ~/.zshrc-secrets.example ~/.zshrc-secrets
# The real file is git-ignored; this template is tracked.
# Sourced by ~/.zshrc; consumed by ~/.zshrc-alias.

# Vultr API keys (vultr-cli)
export VULTR_API_KEY_BT=
export VULTR_API_KEY_Y2B=
